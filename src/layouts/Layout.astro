---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import site from '../../config/site.json';
import { translations } from '../utils/i18n.js';

export interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
  noIndex?: boolean;
  schema?: object;
}

const {
  title,
  description = site.seo.defaultDescription,
  keywords = site.seo.defaultKeywords,
  ogImage = site.seo.ogImage,
  canonical,
  noIndex = false,
  schema,
} = Astro.props;

const pageTitle = title
  ? `${title}${site.seo.titleSuffix}`
  : site.seo.defaultTitle;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site.seo.siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${site.seo.siteUrl}${ogImage}`;

const companySchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.company.name,
  url: site.seo.siteUrl,
  logo: `${site.seo.siteUrl}/images/logo.svg`,
  description: site.company.description,
  telephone: site.contact.phoneRaw,
  email: site.contact.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: `${site.contact.address.line1}, ${site.contact.address.line2}`,
    addressLocality: site.contact.address.city,
    addressRegion: site.contact.address.state,
    postalCode: site.contact.address.pincode,
    addressCountry: 'IN',
  },
  sameAs: [
    site.social.facebook,
    site.social.instagram,
    site.social.linkedin,
    site.social.youtube,
  ],
};
---

<!DOCTYPE html>
<html lang="en-IN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#e57c00" />
    
    <script is:inline define:vars={{ translations }}>
      window.__translations = translations;
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.company.name} />
    <meta property="og:locale" content={site.seo.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={site.seo.twitterHandle} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(companySchema)} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <!-- Preload critical assets -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@300;400;500;600;700;800;900&display=swap" />

    <style is:inline>
      /* Hide Google Translate top bar and banners */
      body {
        top: 0px !important;
      }
      .skiptranslate {
        display: none !important;
      }
      .goog-te-banner-frame {
        display: none !important;
      }
      .goog-te-balloon-frame {
        display: none !important;
      }
      #goog-gt-tt {
        display: none !important;
      }
      .goog-text-highlight {
        background-color: transparent !important;
        box-shadow: none !important;
      }
    </style>
  </head>
  <body class="antialiased">
    <!-- Skip Navigation -->
    <a href="#main-content" class="skip-nav">Skip to main content</a>

    <!-- Navbar -->
    <Navbar />

    <!-- Main Content -->
    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <Footer />

    <!-- Floating WhatsApp Widget -->
    <a
      href={`https://wa.me/${site.contact.whatsapp}?text=${encodeURIComponent(site.contact.whatsappMessage)}`}
      target="_blank"
      rel="noopener noreferrer"
      class="whatsapp-float"
      aria-label="Chat on WhatsApp"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
    </a>

    <!-- Reading Progress (only for blog pages) -->
    <div id="reading-progress" style="width: 0%"></div>

    <script>
      // Smart WhatsApp Redirection
      (window as any).openWhatsApp = function(phone: string, text: string, targetBlank = true) {
        const cleanPhone = phone.replace(/\D/g, '');
        const finalPhone = cleanPhone.startsWith('91') && cleanPhone.length > 10 ? cleanPhone : `91${cleanPhone}`;
        const encodedText = encodeURIComponent(text);
        const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);

        const nativeUrl = `whatsapp://send?phone=${finalPhone}&text=${encodedText}`;
        const webUrl = isMobile 
          ? `https://api.whatsapp.com/send?phone=${finalPhone}&text=${encodedText}` 
          : `https://web.whatsapp.com/send?phone=${finalPhone}&text=${encodedText}`;

        if (isMobile) {
          if (targetBlank) {
            window.open(webUrl, '_blank');
          } else {
            window.location.href = webUrl;
          }
          return;
        }

        // Desktop: Open WhatsApp Web directly in a new tab first
        window.open(webUrl, '_blank');

        // Show native fallback modal on our website
        const modal = document.getElementById('whatsapp-modal');
        const nativeBtn = document.getElementById('whatsapp-modal-native-btn') as HTMLAnchorElement;
        
        if (modal && nativeBtn) {
          nativeBtn.href = nativeUrl;
          modal.classList.remove('hidden');
        }
      };

      // Setup WhatsApp modal close events
      const initWhatsAppModal = () => {
        const modal = document.getElementById('whatsapp-modal');
        const closeBtn = document.getElementById('whatsapp-modal-close-btn');
        const closeConfirm = document.getElementById('whatsapp-modal-close-confirm');
        const nativeBtn = document.getElementById('whatsapp-modal-native-btn');

        const closeModal = () => {
          modal?.classList.add('hidden');
        };

        closeBtn?.addEventListener('click', closeModal);
        closeConfirm?.addEventListener('click', closeModal);
        nativeBtn?.addEventListener('click', closeModal);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initWhatsAppModal);
      } else {
        initWhatsAppModal();
      }

      // Intercept wa.me and api.whatsapp.com clicks
      document.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement).closest('a');
        if (!target) return;
        const href = target.getAttribute('href');
        if (!href) return;
        
        if (href.includes('wa.me/') || href.includes('api.whatsapp.com/send')) {
          e.preventDefault();
          let phone = '';
          let text = '';
          
          try {
            const url = new URL(href, window.location.href);
            if (href.includes('wa.me/')) {
              phone = url.pathname.replace(/^\//, '');
              text = url.searchParams.get('text') || '';
            } else {
              phone = url.searchParams.get('phone') || '';
              text = url.searchParams.get('text') || '';
            }
          } catch (err) {
            const match = href.match(/(?:wa\.me|api\.whatsapp\.com\/send.*?phone=)\/?([^?#&]+)/);
            if (match) phone = match[1];
            const textMatch = href.match(/[?&]text=([^&]+)/);
            if (textMatch) text = decodeURIComponent(textMatch[1]);
          }
          
          (window as any).openWhatsApp(phone, text, true);
        }
      });

      // Reading progress bar
      const progress = document.getElementById('reading-progress');
      if (progress) {
        const article = document.querySelector('article');
        if (article) {
          progress.style.display = 'block';
          window.addEventListener('scroll', () => {
            const rect = article.getBoundingClientRect();
            const total = article.offsetHeight - window.innerHeight;
            const scrolled = Math.max(0, -rect.top);
            const pct = Math.min(100, (scrolled / total) * 100);
            progress.style.width = pct + '%';
          });
        } else {
          progress.style.display = 'none';
        }
      }

      // Back to top functionality
      const backToTop = document.querySelector('[data-back-to-top]');
      if (backToTop) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 400) {
            backToTop.classList.remove('opacity-0', 'pointer-events-none');
          } else {
            backToTop.classList.add('opacity-0', 'pointer-events-none');
          }
        });
        backToTop.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // Multi-language client-side i18n
      function getStoredLanguage() {
        try {
          return localStorage.getItem('solarelites_lang') || 'en';
        } catch (e) {
          return 'en';
        }
      }

      function setStoredLanguage(lang: string) {
        try {
          return localStorage.setItem('solarelites_lang', lang);
        } catch (e) {
          console.warn('Storage access not allowed', e);
        }
      }

      function translatePage(lang: string) {
        const dictionary = (window as any).__translations?.[lang];
        if (dictionary) {
          document.querySelectorAll('[data-i18n]').forEach(el => {
            const key = el.getAttribute('data-i18n');
            if (!key) return;
            const value = dictionary[key];
            if (value) {
              if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                el.setAttribute('placeholder', value);
              } else {
                el.innerHTML = value;
              }
            }
          });
        }

        // Sync dropdowns
        document.querySelectorAll('.lang-select-dropdown').forEach(sel => {
          (sel as HTMLSelectElement).value = lang;
        });

        // Sync mobile language buttons
        document.querySelectorAll('.mobile-lang-btn').forEach(btn => {
          const btnLang = btn.getAttribute('data-lang');
          if (btnLang === lang) {
            btn.classList.add('bg-[#e57c00]', 'text-white', 'border-[#e57c00]');
            btn.classList.remove('bg-transparent', 'text-[rgba(10,11,13,0.6)]', 'border-[rgba(10,11,13,0.1)]');
            (btn as HTMLButtonElement).style.backgroundColor = '#e57c00';
            (btn as HTMLButtonElement).style.color = '#ffffff';
            (btn as HTMLButtonElement).style.borderColor = '#e57c00';
          } else {
            btn.classList.remove('bg-[#e57c00]', 'text-white', 'border-[#e57c00]');
            btn.classList.add('bg-transparent', 'text-[rgba(10,11,13,0.6)]', 'border-[rgba(10,11,13,0.1)]');
            (btn as HTMLButtonElement).style.backgroundColor = 'transparent';
            (btn as HTMLButtonElement).style.color = 'rgba(10, 11, 13, 0.6)';
            (btn as HTMLButtonElement).style.borderColor = 'rgba(10, 11, 13, 0.1)';
          }
        });

        // Set document language attribute
        document.documentElement.setAttribute('lang', lang === 'en' ? 'en-IN' : lang === 'hi' ? 'hi-IN' : 'mr-IN');

        // Trigger Google Translate for whole-page machine translation
        const triggerGoogle = () => {
          const googleCombo = document.querySelector('.goog-te-combo') as HTMLSelectElement;
          if (googleCombo) {
            googleCombo.value = lang === 'en' ? '' : lang;
            googleCombo.dispatchEvent(new Event('change'));
            return true;
          }
          return false;
        };

        if (!triggerGoogle()) {
          let attempts = 0;
          const interval = setInterval(() => {
            attempts++;
            if (triggerGoogle() || attempts > 20) {
              clearInterval(interval);
            }
          }, 150);
        }
      }

      function setupLanguage() {
        const initialLang = getStoredLanguage();
        translatePage(initialLang);

        // Attach listeners and sync selectors
        document.querySelectorAll('.lang-select-dropdown').forEach(sel => {
          (sel as HTMLSelectElement).value = initialLang;
          
          sel.addEventListener('change', (e) => {
            const newLang = (e.target as HTMLSelectElement).value;
            setStoredLanguage(newLang);
            translatePage(newLang);
          });
        });

        // Attach listeners to mobile buttons
        document.querySelectorAll('.mobile-lang-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const newLang = btn.getAttribute('data-lang');
            if (newLang) {
              setStoredLanguage(newLang);
              translatePage(newLang);
            }
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupLanguage);
      } else {
        setupLanguage();
      }
    </script>

    <!-- WhatsApp Redirection Dialog -->
    <div id="whatsapp-modal" class="fixed inset-0 z-[9999] flex items-center justify-center hidden bg-[rgba(10,11,13,0.4)] backdrop-blur-[2px] transition-opacity duration-200" aria-modal="true" role="dialog" aria-labelledby="whatsapp-modal-title">
      <div class="relative bg-white rounded-[24px] p-8 max-w-sm w-full mx-4 shadow-2xl border border-[rgba(10,11,13,0.1)]">
        <button id="whatsapp-modal-close-btn" class="absolute top-4 right-4 text-[rgba(10,11,13,0.6)] hover:text-[#0a0b0d] cursor-pointer" aria-label="Close dialog" style="background: none; border: none;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        
        <div class="text-center" style="display: flex; flex-direction: column; align-items: center;">
          <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-[rgba(229,124,0,0.08)] mb-4" style="margin-bottom: 16px;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
          </div>
          
          <h3 id="whatsapp-modal-title" class="type-title-lg mb-2" style="margin-bottom: 8px;">Connecting to WhatsApp</h3>
          <p class="type-body-sm mb-6" style="color: var(--muted); margin-bottom: 24px; font-size: 14px; line-height: 1.5;">
            We've opened WhatsApp Web in a new tab. If you are not logged in there, click below to try opening the native desktop app.
          </p>
          
          <div style="display: flex; flex-direction: column; gap: 8px; width: 100%;">
            <a id="whatsapp-modal-native-btn" href="#" class="btn-primary w-full justify-center">
              Open Native App
            </a>
            <button id="whatsapp-modal-close-confirm" class="btn-secondary w-full justify-center" style="border: 1px solid var(--hairline);">
              I'm using WhatsApp Web
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Hidden Google Translate Element and Script -->
    <div id="google_translate_element" style="display:none; visibility:hidden; position:absolute; z-index:-1000; left:-1000px; top:-1000px;"></div>
    <script is:inline>
      window.googleTranslateElementInit = function() {
        new google.translate.TranslateElement({
          pageLanguage: 'en',
          includedLanguages: 'hi,mr',
          layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
          autoDisplay: false
        }, 'google_translate_element');
      };
    </script>
    <script is:inline src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
  </body>
</html>
