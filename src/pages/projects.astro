---
import Layout from '../layouts/Layout.astro';
import site from '../../config/site.json';
---

<Layout
  title="Completed Solar Projects – Case Studies in Maharashtra"
  description="Explore Solarelites' completed solar installation projects — residential, commercial, and industrial case studies from across Maharashtra."
>
  <!-- Hero — band-light, display-xl weight 400 -->
  <section class="relative subpage-hero band-light" aria-labelledby="projects-heading">
    <div class="container text-center">
      <h1 id="projects-heading" class="aurora-title" style="font-size: clamp(36px, 7vw, 72px); margin-bottom: 24px;" data-i18n="projects.hero.title">
        Real Projects, Real Savings
        <span class="aurora-overlay" aria-hidden="true">
          <span class="aurora-overlay__item"></span>
          <span class="aurora-overlay__item"></span>
          <span class="aurora-overlay__item"></span>
          <span class="aurora-overlay__item"></span>
        </span>
      </h1>
      <p style="font-size: 18px; color: var(--body-color); max-width: 600px; margin-inline: auto; line-height: 1.6;" data-i18n="projects.hero.subtitle">
        Every project we complete is a step towards a cleaner Maharashtra. Here are some of our most impactful solar installations.
      </p>
    </div>
  </section>

  <!-- Stats — light band -->
  <section class="band-light" style="padding-block: 48px;" aria-label="Company statistics">
    <div class="container">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {site.statistics.map(stat => (
          <div class="card-cream text-center" style="background: var(--cream); border: 1px solid var(--beige-deep); border-radius: var(--radius-lg); padding: var(--spacing-xl); display: flex; flex-direction: column; align-items: center; justify-content: center;">
            <div style="font-family: var(--font-display); font-size: clamp(36px, 5vw, 56px); font-weight: 400; color: var(--ink); letter-spacing: -1.5px; line-height: 1.1; margin-bottom: 8px;">{stat.value}</div>
            <div style="font-size: 14px; font-weight: 500; color: var(--ink); line-height: 1.4;" data-i18n={stat.label === "Installations Completed" ? "stats.installations" : stat.label === "Total Capacity Installed" ? "stats.capacity" : stat.label === "Subsidy Secured" ? "stats.subsidy" : "stats.satisfaction"}>{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Projects — band-soft -->
  <section class="section band-soft" aria-labelledby="featured-projects-heading">
    <div class="container">
      <h2 id="featured-projects-heading" class="type-display-md" style="margin-bottom: 48px;" data-i18n="projects.featured.title">Featured Case Studies</h2>
      <div style="display: flex; flex-direction: column; gap: 40px;">
        {[
          {
            id: 'project1',
            title: '500 kW Industrial Solar Plant – Pune, Maharashtra',
            category: 'Industrial',
            client: 'Auto Components Manufacturer',
            size: '500 kW',
            savings: '₹48L/year',
            panels: '1,200 Mono PERC panels',
            inverter: 'SMA Central Inverter',
            time: '6 weeks',
            subsidy: 'Accelerated Depreciation – ₹60L Year 1',
            description: 'A 500 kW rooftop solar installation on a 40,000 sq ft factory roof in Pune. The system generates 7.3 lakh units annually, offsetting 100% of the factory\'s daytime electricity consumption and delivering ₹48 lakh in annual savings.',
            tags: ['Industrial', 'Rooftop', 'Net Metering'],
          },
          {
            id: 'project2',
            title: '25 kW Commercial Solar – IT Office, Pune, Maharashtra',
            category: 'Commercial',
            client: 'IT Services Company',
            size: '25 kW',
            savings: '₹3.6L/year',
            panels: '60 Bifacial panels',
            inverter: 'SolarEdge String Inverter',
            time: '5 days',
            subsidy: '40% Accelerated Depreciation',
            description: 'A 25 kW rooftop solar system installed for an IT company in Pune\'s tech corridor. With 8,000+ sq ft of roof space, the system covers 65% of daytime electricity needs and integrates with the building\'s smart energy management system.',
            tags: ['Commercial', 'Smart Monitoring', 'Green Building'],
          },
          {
            id: 'project3',
            title: '6.6 kW Residential Solar – Mumbai Bungalow',
            category: 'Residential',
            client: 'Private Homeowner',
            size: '6.6 kW',
            savings: '₹90,000/year',
            panels: '16 Waaree 415W panels',
            inverter: 'Growatt Hybrid Inverter',
            time: '2 days',
            subsidy: 'PM Surya Ghar – ₹78,000',
            description: 'A premium hybrid solar system with 10 kWh battery storage for a large family bungalow in South Mumbai. The system provides uninterrupted power during grid outages and has reduced the monthly electricity bill from ₹12,000 to under ₹800.',
            tags: ['Residential', 'Hybrid', 'Battery Storage'],
          },
        ].map((project) => (
          <div class="feature-card" style="display: grid; grid-template-columns: 1fr; gap: 32px; background: var(--canvas);" class="md:grid-cols-2">
            <div>
              <span class="badge-pill" style="margin-bottom: 16px;" data-i18n={"services." + project.category.toLowerCase() + ".title"}>{project.category}</span>
              <h3 class="type-title-lg" style="margin-bottom: 16px; font-weight: 600;" data-i18n={"projects." + project.id + ".title"}>{project.title}</h3>
              <p style="font-size: 15px; line-height: 1.6; color: var(--body-color); margin-bottom: 24px;" data-i18n={"projects." + project.id + ".desc"}>{project.description}</p>
              <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px;">
                {project.tags.map(tag => (
                  <span class="badge-pill" style="background: var(--surface-soft); color: var(--body-color); font-size: 11px; font-weight: 500;" data-i18n={tag === 'Rooftop' ? 'projects.tag.rooftop' : tag === 'Smart Monitoring' ? 'projects.tag.smart_monitoring' : tag === 'Green Building' ? 'projects.tag.green_building' : tag === 'Hybrid' ? 'projects.tag.hybrid' : tag === 'Battery Storage' ? 'projects.tag.battery_storage' : tag === 'PM-KUSUM' ? 'projects.tag.pm_kusum' : tag === 'Drip Irrigation' ? 'projects.tag.drip_irrigation' : tag === 'Net Metering' ? 'process.step5.title' : tag === 'Industrial' ? 'services.industrial.title' : tag === 'Commercial' ? 'services.commercial.title' : tag === 'Residential' ? 'services.residential.title' : 'services.agriculture.title'}>{tag}</span>
                ))}
              </div>
              <a href="/contact" style="font-size: 14px; font-weight: 600; color: var(--primary); text-decoration: none; display: inline-flex; align-items: center; gap: 4px;" data-i18n="projects.cta.similar_quote">
                Get similar system quote →
              </a>
            </div>
            <div style="display: flex; flex-direction: column; gap: 2px;">
              {[
                { label: 'System Size', value: project.size, key: 'projects.table.system_size' },
                { label: 'Annual Savings', value: project.savings, key: 'projects.table.annual_savings' },
                { label: 'Solar Panels', value: project.panels, key: 'projects.table.solar_panels', valKey: `projects.${project.id}.panels` },
                { label: 'Inverter', value: project.inverter, key: 'projects.table.inverter', valKey: `projects.${project.id}.inverter` },
                { label: 'Installation Time', value: project.time, key: 'services.table.installation_time', valKey: `projects.${project.id}.time` },
                { label: 'Subsidy / Incentive', value: project.subsidy, key: 'projects.table.subsidy_incentive', valKey: `projects.${project.id}.subsidy` },
              ].map(detail => (
                <div style="display: flex; justify-content: space-between; align-items: center; padding-block: 10px; border-bottom: 1px solid var(--hairline-soft);" class="last:border-0">
                  <span style="font-size: 13px; color: var(--muted);" data-i18n={detail.key}>{detail.label}</span>
                  <span style="font-size: 13px; font-weight: 600; color: var(--ink); text-align: right; max-width: 60%;" data-i18n={detail.valKey}>{detail.value}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Coverage Map — band-light -->
  <section class="section band-light" aria-labelledby="coverage-heading">
    <div class="container">
      <div style="text-align: center; margin-bottom: 48px;">
        <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: var(--primary); margin-bottom: 16px;" data-i18n="projects.coverage.badge">Coverage</p>
        <h2 id="coverage-heading" class="type-display-md" style="margin-bottom: 16px;" data-i18n="projects.coverage.title">We serve Maharashtra.</h2>
        <p style="font-size: 16px; color: var(--body-color);" data-i18n="projects.coverage.subtitle">Providing premium solar engineering and empanelled subsidies across key districts.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {site.coverage.primaryCities.map(city => (
          <div class="feature-card" style="text-align: center; padding: 20px; background: var(--canvas);">
            <div style="font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 4px;" data-i18n={`city.${city.city.toLowerCase().replace(' ', '_')}`}>{city.city}</div>
            <div style="font-size: 12px; color: var(--muted);" data-i18n={`state.${city.state.toLowerCase()}`}>{city.state}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — band-dark -->
  <section class="section band-soft" style="text-align: center;">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: clamp(32px, 4.5vw, 52px); font-weight: 400; line-height: 1.0; letter-spacing: -1.3px; color: var(--ink); margin-bottom: 20px; max-width: 560px; margin-inline: auto;" data-i18n="projects.cta.title">Become Our Next Success Story</h2>
      <p style="font-size: 16px; color: var(--body-color); margin-bottom: 40px; max-width: 480px; margin-inline: auto; line-height: 1.6;" data-i18n="projects.cta.subtitle">Join thousands of satisfied customers and start your solar journey today.</p>
      <div style="display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;">
        <a href="/contact" class="btn-primary-lg" data-i18n="hero.cta.consult">Get Free Consultation</a>
        <a href="/gallery" class="btn-outline-dark" data-i18n="projects.cta.gallery">View Gallery</a>
      </div>
    </div>
  </section>
</Layout>
