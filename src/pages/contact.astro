---
import Layout from '../layouts/Layout.astro';
import site from '../../config/site.json';
---

<Layout
  title="Contact Us – Get a Free Solar Consultation"
  description="Contact Solarelites for a free solar consultation, site assessment, and quote. Call, WhatsApp, or fill out our form. We serve Maharashtra."
>
  <!-- Hero — band-light, display-xl weight 400 -->
  <section class="relative pt-48 pb-16 band-light" aria-labelledby="contact-heading">
    <div class="container text-center">
      <h1 id="contact-heading" class="type-display-xl" style="margin-bottom: 24px;" data-i18n="contact.hero.title">
        Let's Talk Solar
      </h1>
      <p style="font-size: 18px; color: var(--body-color); max-width: 600px; margin-inline: auto; line-height: 1.6;" data-i18n="contact.hero.subtitle">
        Our solar experts are ready to help you make the switch. Free consultation, no obligation.
      </p>
    </div>
  </section>

  <!-- Content Section — band-soft -->
  <section class="section band-soft">
    <div class="container">
      <div class="grid lg:grid-cols-[1fr_400px] gap-16 max-w-6xl mx-auto items-start">

        <!-- Form -->
        <div>
          <h2 class="type-display-sm" style="margin-bottom: 32px;" data-i18n="contact.form.title">Request a Free Quote</h2>
          <form id="contact-form" class="space-y-5" novalidate aria-label="Contact and quote request form" data-email={site.contact.email} data-whatsapp={site.contact.whatsapp}>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;"><span data-i18n="contact.form.name">Full Name</span> <span aria-label="required" style="color: var(--semantic-down);">*</span></label>
                <input type="text" id="name" name="name" required autocomplete="name"
                  class="cb-input w-full"
                  placeholder="Rajesh Sharma"
                />
                <span class="hidden text-xs mt-1" style="color: var(--semantic-down);" id="name-error" role="alert" data-i18n="contact.form.name-error">Please enter your name.</span>
              </div>
              <div>
                <label for="phone" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;"><span data-i18n="contact.form.phone">Mobile Number</span> <span aria-label="required" style="color: var(--semantic-down);">*</span></label>
                <div style="display: flex;">
                  <span style="display: inline-flex; align-items: center; padding-inline: 16px; font-size: 14px; font-weight: 500; border: 1px solid var(--hairline); border-right: 0; border-top-left-radius: 12px; border-bottom-left-radius: 12px; background: var(--surface-soft); color: var(--muted);">+91</span>
                  <input type="tel" id="phone" name="phone" required maxlength="10" pattern="[6-9][0-9]{9}" autocomplete="tel"
                    class="cb-input flex-1"
                    style="border-top-left-radius: 0; border-bottom-left-radius: 0;"
                    placeholder="9822625918"
                  />
                </div>
                <span class="hidden text-xs mt-1" style="color: var(--semantic-down);" id="phone-error" role="alert" data-i18n="contact.form.phone-error">Enter a valid 10-digit Indian mobile number.</span>
              </div>
            </div>

            <div>
              <label for="email" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;" data-i18n="contact.form.email">Email Address</label>
              <input type="email" id="email" name="email" autocomplete="email"
                class="cb-input w-full"
                placeholder="rajesh@example.com"
              />
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="state" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;"><span data-i18n="contact.form.state">State</span> <span aria-label="required" style="color: var(--semantic-down);">*</span></label>
                <select id="state" name="state" required class="cb-select w-full">
                  <option value="" data-i18n="contact.form.select_state">Select State</option>
                  {site.coverage.states.map(s => <option value={s} selected={s === 'Maharashtra'}>{s}</option>)}
                </select>
              </div>
              <div>
                <label for="city" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;" data-i18n="contact.form.city">City / District</label>
                <input type="text" id="city" name="city" autocomplete="address-level2"
                  class="cb-input w-full"
                  placeholder="Mumbai"
                />
              </div>
            </div>

            <div>
              <label for="address" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;" data-i18n="contact.form.address">Property Address</label>
              <input type="text" id="address" name="address" autocomplete="street-address"
                class="cb-input w-full"
                placeholder="Flat/Building, Street, Area, Pincode"
              />
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="propertyType" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;" data-i18n="contact.form.propertyType">Property Type</label>
                <select id="propertyType" name="propertyType" class="cb-select w-full">
                  <option value="" data-i18n="contact.form.select_type">Select Type</option>
                  <option value="Residential – Independent House" data-i18n="contact.form.prop_res_ind">Residential – Independent House</option>
                  <option value="Residential – Apartment" data-i18n="contact.form.prop_res_apt">Residential – Apartment</option>
                  <option value="Commercial – Office" data-i18n="contact.form.prop_com_off">Commercial – Office</option>
                  <option value="Commercial – Retail" data-i18n="contact.form.prop_com_ret">Commercial – Retail</option>
                  <option value="Industrial – Factory/Warehouse" data-i18n="contact.form.prop_ind">Industrial – Factory/Warehouse</option>
                  <option value="Agricultural – Farm" data-i18n="contact.form.prop_agri">Agricultural – Farm</option>
                </select>
              </div>
              <div>
                <label for="monthlyBill" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;" data-i18n="contact.form.monthlyBill">Monthly Electricity Bill (₹)</label>
                <input type="number" id="monthlyBill" name="monthlyBill" min="0" inputmode="numeric"
                  class="cb-input w-full"
                  placeholder="3000"
                />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="roofArea" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;" data-i18n="contact.form.roofArea">Approximate Roof Area (sq ft)</label>
                <input type="number" id="roofArea" name="roofArea" min="0" inputmode="numeric"
                  class="cb-input w-full"
                  placeholder="500"
                />
              </div>
              <div>
                <label for="callbackTime" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;" data-i18n="contact.form.callbackTime">Preferred Callback Time</label>
                <select id="callbackTime" name="callbackTime" class="cb-select w-full">
                  <option value="" data-i18n="contact.form.time_any">Any Time</option>
                  <option value="Morning (9 AM – 12 PM)" data-i18n="contact.form.time_morning">Morning (9 AM – 12 PM)</option>
                  <option value="Afternoon (12 PM – 3 PM)" data-i18n="contact.form.time_afternoon">Afternoon (12 PM – 3 PM)</option>
                  <option value="Evening (3 PM – 6 PM)" data-i18n="contact.form.time_evening">Evening (3 PM – 6 PM)</option>
                </select>
              </div>
            </div>

            <!-- Subsidy checkbox -->
            <div style="display: flex; align-items: center; gap: 10px;">
              <input type="checkbox" id="subsidyRequired" name="subsidyRequired" class="w-4 h-4 rounded" style="accent-color: #e57c00; cursor: pointer;" />
              <label for="subsidyRequired" style="font-size: 14px; color: var(--body-color); cursor: pointer;" data-i18n="contact.form.subsidyRequired">I need assistance with government subsidy application</label>
            </div>

            <div>
              <label for="message" style="display: block; font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 8px;" data-i18n="contact.form.message">Additional Message</label>
              <textarea id="message" name="message" rows="4"
                class="cb-textarea w-full"
                data-i18n="contact.form.message_placeholder"
                placeholder="Tell us more about your solar requirements..."
              ></textarea>
            </div>

            <!-- Submit -->
            <button type="submit" id="submit-btn" class="btn-primary w-full justify-center" data-i18n="contact.form.submit">
              Submit Request
            </button>

            <!-- Success/Error messages -->
            <div id="form-success" class="hidden p-4 rounded-xl text-sm font-500" style="background: rgba(229,124,0,0.06); color: #e57c00; border: 1px solid rgba(229,124,0,0.15);" role="alert" data-i18n="contact.form.success">
              Thank you! We've received your request and will contact you within 24 hours.
            </div>
            <div id="form-error" class="hidden p-4 rounded-xl text-sm font-500" style="background: rgba(232,93,117,0.06); color: var(--semantic-down); border: 1px solid rgba(232,93,117,0.15);" role="alert" data-i18n="contact.form.error">
              Something went wrong. Please call us directly.
            </div>
          </form>
        </div>

        <!-- Contact Info Sidebar -->
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <!-- Quick Contact Cards -->
          {[
            { icon: 'phone', labelKey: 'contact.sidebar.sales', value: site.contact.phone, href: `tel:${site.contact.phoneRaw}`, descKey: 'contact.sidebar.sales_desc' },
            { icon: 'message-circle', labelKey: 'contact.sidebar.whatsapp', valueKey: 'contact.sidebar.chat_with_us', href: `https://wa.me/${site.contact.whatsapp}?text=${encodeURIComponent(site.contact.whatsappMessage)}`, descKey: 'contact.sidebar.quick_resp' },
            { icon: 'mail', labelKey: 'contact.sidebar.email', value: site.contact.email, href: `mailto:${site.contact.email}`, descKey: 'contact.sidebar.resp_4h' },
            { icon: 'phone', labelKey: 'contact.sidebar.emergency', value: site.contact.emergencyPhone, href: `tel:${site.contact.emergencyPhone.replace(/-/g,'')}`, descKey: 'contact.sidebar.urgent_issues' },
          ].map(card => (
            <a href={card.href} target={card.icon === 'message-circle' ? '_blank' : undefined} rel={card.icon === 'message-circle' ? 'noopener noreferrer' : undefined}
              class="feature-card block hover:border-[#e57c00]/40"
              style="text-decoration: none; background: var(--canvas); display: flex; align-items: start; gap: 16px; padding: 20px; transition: border-color 0.15s ease;"
            >
              <div style="width: 40px; height: 40px; border-radius: 9999px; background: var(--surface-strong); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  {card.icon === 'phone' && <><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.63 4.35 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></>}
                  {card.icon === 'message-circle' && <><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></>}
                  {card.icon === 'mail' && <><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></>}
                </svg>
              </div>
              <div>
                <div style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--muted); margin-bottom: 4px;" data-i18n={card.labelKey}>Label</div>
                <div style="font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 2px;" data-i18n={card.valueKey || ''}>{card.value}</div>
                <div style="font-size: 12px; color: var(--muted);" data-i18n={card.descKey}>Description</div>
              </div>
            </a>
          ))}

          <!-- Address -->
          <div class="feature-card" style="background: var(--canvas); display: flex; align-items: start; gap: 16px; padding: 20px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <div style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--muted); margin-bottom: 4px;" data-i18n="contact.sidebar.addressTitle">Office Address</div>
              <address style="font-size: 13px; color: var(--body-color); not-italic; line-height: 1.6;">
                <span data-i18n="contact.sidebar.address_line1">{site.contact.address.line1}</span>,<br />
                <span data-i18n="contact.sidebar.address_line2">{site.contact.address.line2}</span>
              </address>
            </div>
          </div>

          <!-- Maps Embed -->
          <div style="border-radius: var(--radius-xl); overflow: hidden; border: 1px solid var(--hairline);" aria-label="Office location map">
            <iframe
              src={site.contact.googleMapsUrl}
              width="100%"
              height="250"
              style="border: 0; display: block;"
              allowfullscreen={false}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Solarelites office location"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  // Phone validation: starts with 6-9, exactly 10 digits
  function validatePhone(val: string) {
    return /^[6-9]\d{9}$/.test(val.replace(/\s/g,''));
  }

  function showError(id: string) {
    const el = document.getElementById(id);
    el?.classList.remove('hidden');
  }
  function hideError(id: string) {
    const el = document.getElementById(id);
    el?.classList.add('hidden');
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    let valid = true;

    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('phone') as HTMLInputElement).value.trim();

    if (!name) { showError('name-error'); valid = false; } else hideError('name-error');
    if (!validatePhone(phone)) { showError('phone-error'); valid = false; } else hideError('phone-error');

    if (!valid) return;

    // Simulate form submission
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;

    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const state = (document.getElementById('state') as HTMLSelectElement).value;
    const city = (document.getElementById('city') as HTMLInputElement).value.trim();
    const address = (document.getElementById('address') as HTMLInputElement).value.trim();
    const propertyType = (document.getElementById('propertyType') as HTMLSelectElement).value;
    const monthlyBill = (document.getElementById('monthlyBill') as HTMLInputElement).value.trim();
    const roofArea = (document.getElementById('roofArea') as HTMLInputElement).value.trim();
    const callbackTime = (document.getElementById('callbackTime') as HTMLSelectElement).value;
    const subsidyRequired = (document.getElementById('subsidyRequired') as HTMLInputElement).checked ? 'Yes' : 'No';
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

    // Construct beautiful message
    let text = `*New Solar Quote Request* ☀️\n\n`;
    text += `*Name:* ${name}\n`;
    text += `*Phone:* +91 ${phone}\n`;
    if (email) text += `*Email:* ${email}\n`;
    text += `*State:* ${state || 'Maharashtra'}\n`;
    if (city) text += `*City/District:* ${city}\n`;
    if (address) text += `*Address:* ${address}\n`;
    if (propertyType) text += `*Property Type:* ${propertyType}\n`;
    if (monthlyBill) text += `*Monthly Bill:* ₹${monthlyBill}\n`;
    if (roofArea) text += `*Roof Area:* ${roofArea} sq ft\n`;
    text += `*Subsidy Assistance:* ${subsidyRequired}\n`;
    if (callbackTime) text += `*Callback Time:* ${callbackTime}\n`;
    if (message) text += `*Message:* ${message}\n`;

    const whatsappNumber = form.getAttribute('data-whatsapp') || '919822625918';
    const cleanNumber = whatsappNumber.replace(/\D/g, '');
    const finalNumber = cleanNumber.startsWith('91') && cleanNumber.length > 10 ? cleanNumber : `91${cleanNumber}`;
    const whatsappLink = `https://wa.me/${finalNumber}?text=${encodeURIComponent(text)}`;

    setTimeout(() => {
      submitBtn.textContent = 'Submit Request';
      submitBtn.disabled = false;
      successMsg?.classList.remove('hidden');
      form.reset();
      
      // Redirect to WhatsApp message automatically
      window.location.href = whatsappLink;
    }, 1000);
  });

  // Live phone validation
  document.getElementById('phone')?.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value.replace(/\D/g, '').slice(0, 10);
    (e.target as HTMLInputElement).value = val;
  });
</script>
