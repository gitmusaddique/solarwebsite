---
import Layout from '../layouts/Layout.astro';
import site from '../../config/site.json';
---

<Layout
  title="About Us – Maharashtra's Solar Energy Leaders"
  description="Learn about Solarelites – our mission, team, values, and 7-year journey to becoming Maharashtra's most trusted solar installation company."
>
  <!-- Hero — band-light, display-xl weight 400 -->
  <section class="relative pt-48 pb-16 band-light" aria-labelledby="about-heading">
    <div class="container text-center">
      <div class="max-w-3xl" style="margin-inline: auto;">
        <h1 id="about-heading" class="type-display-xl" style="margin-bottom: 24px;" data-i18n="about.hero.title">
          We believe every home and business deserves clean, affordable energy.
        </h1>
        <p style="font-size: 18px; color: var(--body-color); line-height: 1.6;" data-i18n="about.hero.subtitle">
          Founded in 2019 as Vicky Enterprises and rebranded as Solar Elites in 2024, we are Maharashtra's most trusted solar energy company — completing 1,000+ installations and 3MW+ capacity across the state.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats Banner — light band -->
  <section class="band-light" style="padding-block: 48px;" aria-label="Company milestones">
    <div class="container">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
        {site.statistics.map(stat => (
          <div>
            <div style="font-family: var(--font-mono); font-size: 32px; font-weight: 500; color: #0a0b0d; letter-spacing: -0.5px; margin-bottom: 4px;">{stat.value}</div>
            <div style="font-size: 14px; color: var(--body-color);" data-i18n={stat.label === "Installations Completed" ? "stats.installations" : stat.label === "Total Capacity Installed" ? "stats.capacity" : stat.label === "Subsidy Secured" ? "stats.subsidy" : "stats.satisfaction"}>{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mission & Vision — band-soft -->
  <section class="section band-soft" aria-labelledby="mission-heading">
    <div class="container">
      <div class="grid md:grid-cols-2 gap-16 items-center max-w-5xl mx-auto">
        <div>
          <h2 id="mission-heading" class="type-display-sm" style="margin-bottom: 16px;" data-i18n="about.mission.title">Our Mission</h2>
          <p style="font-size: 15px; line-height: 1.6; color: var(--body-color); margin-bottom: 32px;" data-i18n="about.mission.desc">
            To accelerate Maharashtra's transition to renewable energy by making world-class solar installations accessible and affordable for every home, farm, and business — while ensuring maximum financial returns for our customers through government subsidies and premium engineering.
          </p>
          <h2 class="type-display-sm" style="margin-bottom: 16px;" data-i18n="about.vision.title">Our Vision</h2>
          <p style="font-size: 15px; line-height: 1.6; color: var(--body-color);" data-i18n="about.vision.desc">
            A solar panel on every rooftop in Maharashtra. A clean energy future for every family. By 2030, we aim to complete 1 lakh solar installations — contributing to our state's green energy goals.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {site.values.map(value => (
            <div class="feature-card" style="background: var(--canvas);">
              <div style="width: 36px; height: 36px; border-radius: 9999px; background: var(--surface-strong); display: flex; align-items: center; justify-content: center; margin-bottom: 16px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#e57c00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  {value.icon === 'shield-check' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></>}
                  {value.icon === 'award' && <><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></>}
                  {value.icon === 'leaf' && <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>}
                  {value.icon === 'lightbulb' && <><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></>}
                </svg>
              </div>
              <h3 class="type-title-sm" style="margin-bottom: 8px;" data-i18n={value.icon === "shield-check" ? "about.value.integrity.title" : value.icon === "award" ? "about.value.quality.title" : value.icon === "leaf" ? "about.value.subsidy.title" : "about.value.support.title"}>{value.title}</h3>
              <p style="font-size: 12px; line-height: 1.5; color: var(--body-color);" data-i18n={value.icon === "shield-check" ? "about.value.integrity.desc" : value.icon === "award" ? "about.value.quality.desc" : value.icon === "leaf" ? "about.value.subsidy.desc" : "about.value.support.desc"}>{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline — band-light -->
  <section class="section band-light" aria-labelledby="timeline-heading">
    <div class="container">
      <div style="max-width: 480px; margin-bottom: 64px; margin-inline: auto; text-align: center;">
        <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #e57c00; margin-bottom: 16px;" data-i18n="about.journey.badge">Our Journey</p>
        <h2 id="timeline-heading" class="type-display-md" data-i18n="about.journey.title">Our legacy & journey.</h2>
      </div>
      <div class="max-w-3xl mx-auto">
        {[
          { year: '2019', event: 'Founded Vicky Enterprises.' },
          { year: '2021', event: 'First major solar installation project: 2MW solar installation at Sambhaji Nager.' },
          { year: '2024', event: 'Rebranded as Solar Elites and received MNRE approval.' },
        ].map((item) => (
          <div style="display: flex; gap: 32px; margin-bottom: 48px;" class="last:mb-0">
            <div style="flex-shrink: 0; width: 64px; font-family: var(--font-mono); font-size: 14px; font-weight: 600; color: #e57c00; padding-top: 2px;">{item.year}</div>
            <div style="position: relative; padding-left: 32px; border-left: 1px solid var(--hairline);">
              <div style="position: absolute; left: 0; top: 6px; width: 8px; height: 8px; border-radius: 9999px; background: #e57c00; transform: translateX(-50%);"></div>
              <p style="font-size: 14px; line-height: 1.6; color: var(--body-color);" data-i18n={"about.timeline." + item.year}>{item.event}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team — band-soft -->
  <section class="section band-soft" id="team" aria-labelledby="team-heading">
    <div class="container">
      <div style="max-width: 480px; margin-bottom: 64px; margin-inline: auto; text-align: center;">
        <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #e57c00; margin-bottom: 16px;" data-i18n="about.leadership.badge">Leadership</p>
        <h2 id="team-heading" class="type-display-md" data-i18n="about.leadership.title">Meet the team.</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {site.team.map(member => (
          <div class="feature-card" style="text-align: center; background: var(--canvas);">
            <div style="width: 80px; height: 80px; border-radius: 9999px; margin-inline: auto; margin-bottom: 20px; background: var(--surface-strong); color: #e57c00; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 600;">
              {member.name.split(' ').map((n: string) => n[0]).join('').slice(0,2)}
            </div>
            <h3 class="type-title-sm" style="margin-bottom: 4px;">{member.name}</h3>
            <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #e57c00; margin-bottom: 16px;" data-i18n={"about.team." + member.name.toLowerCase().split(" ")[0] + ".role"}>{member.role}</p>
            <p style="font-size: 13px; color: var(--body-color); line-height: 1.6;" data-i18n={"about.team." + member.name.toLowerCase().split(" ")[0] + ".bio"}>{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Certifications — band-light -->
  <section class="section band-light" id="certifications" aria-labelledby="cert-heading">
    <div class="container">
      <div style="max-width: 480px; margin-bottom: 48px; margin-inline: auto; text-align: center;">
        <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #e57c00; margin-bottom: 16px;" data-i18n="about.qa.badge">Quality Assurance</p>
        <h2 id="cert-heading" class="type-display-md" data-i18n="about.qa.title">Certifications & standards.</h2>
      </div>
      <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 12px;">
        {site.certifications.map(cert => (
          <span class="badge-pill" style="padding: 10px 20px; font-size: 13px; border: 1px solid var(--hairline); background: var(--canvas);" data-i18n={"about.cert." + (cert.includes("MNRE") ? "mnre" : cert.includes("ISO") ? "iso" : cert.includes("MEDA") ? "meda" : "msme")}>
            {cert}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — band-dark -->
  <section class="section band-soft" style="text-align: center;">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: clamp(32px, 4.5vw, 52px); font-weight: 400; line-height: 1.0; letter-spacing: -1.3px; color: var(--ink); margin-bottom: 20px; max-width: 560px; margin-inline: auto;" data-i18n="about.cta.title">
        Ready to work with Maharashtra's best?
      </h2>
      <div style="display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;">
        <a href="/contact" class="btn-primary-lg" data-i18n="hero.cta.consult">Get Free Consultation</a>
        <a href="/projects" class="btn-outline-dark" data-i18n="about.cta.projects">View Our Projects</a>
      </div>
    </div>
  </section>
</Layout>
