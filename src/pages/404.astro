---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found – 404" description="The page you're looking for doesn't exist. Return to Solarelites homepage." noIndex={true}>
  <section class="min-h-screen flex items-center justify-center pt-16" style="background: var(--canvas);">
    <div class="container text-center">
      <div class="font-display font-800 text-[12rem] leading-none select-none" aria-hidden="true" style="color: color-mix(in srgb, var(--primary) 10%, var(--canvas));">404</div>
      <h1 class="font-display font-700 text-4xl md:text-5xl tracking-tight mb-4 -mt-8" style="letter-spacing: -0.02em; color: var(--ink);">Page Not Found</h1>
      <p class="text-lg mb-10 max-w-md mx-auto" style="color: var(--body-color);">
        The page you're looking for has moved or doesn't exist. Let us help you find what you need.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="btn-primary">
          Back to Homepage
        </a>
        <a href="/contact" class="btn-outline-dark">
          Contact Support
        </a>
      </div>
      <div class="mt-16 grid sm:grid-cols-3 gap-4 max-w-xl mx-auto">
        {[
          { label: 'Solar Calculator', href: '/calculator' },
          { label: 'Our Services', href: '/services' },
          { label: 'Government Subsidy', href: '/subsidy' },
        ].map(link => (
          <a href={link.href} class="p-4 rounded-xl text-sm font-500 transition-all" style="background: var(--surface-card); border: 1px solid var(--hairline); color: var(--ink); text-decoration: none;">{link.label}</a>
        ))}
      </div>
    </div>
  </section>
</Layout>
