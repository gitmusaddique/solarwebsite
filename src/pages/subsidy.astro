---
import Layout from '../layouts/Layout.astro';
import site from '../../config/site.json';
---

<Layout
  title="Government Solar Subsidy in Maharashtra – PM Surya Ghar & PM-KUSUM"
  description="Complete guide to PM Surya Ghar Muft Bijli Yojana and PM-KUSUM subsidies in Maharashtra. Eligibility, documents, application process, and how Solarelites handles it all for you."
>
  <!-- Hero — band-light, display-xl weight 400 -->
  <section class="relative pt-48 pb-20 band-light" aria-labelledby="subsidy-main-heading">
    <div class="container text-center">
      <div class="max-w-3xl" style="margin-inline: auto;">
        <h1 id="subsidy-main-heading" class="type-display-xl" style="margin-bottom: 24px;">
          Get Up to ₹78,000 Solar Subsidy
        </h1>
        <p style="font-size: 18px; color: var(--body-color); line-height: 1.6; margin-bottom: 36px;">
          India's PM Surya Ghar Muft Bijli Yojana provides substantial subsidies for rooftop solar installations. Solarelites is an MNRE-empanelled installer in Maharashtra — we handle the entire application process on your behalf.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: center;">
          <a href="/contact" class="btn-primary">
            Apply for Subsidy Assistance
          </a>
          <a href="/calculator" class="btn-secondary">
            Calculate Your Subsidy
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PM Surya Ghar — band-soft -->
  <section class="section band-soft" aria-labelledby="pm-surya-heading">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <div style="text-align: center; margin-bottom: 48px;">
          <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #e57c00; margin-bottom: 16px;">Central Government Scheme</p>
          <h2 id="pm-surya-heading" class="type-display-md" style="margin-bottom: 16px;">
            PM Surya Ghar Muft Bijli Yojana
          </h2>
          <p style="font-size: 16px; color: var(--body-color); max-width: 560px; margin-inline: auto; line-height: 1.6;">
            {site.subsidyInfo.pmSuryaGhar.description}
          </p>
        </div>

        <!-- Subsidy Rates Grid — 4 feature cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
          {site.subsidyInfo.pmSuryaGhar.subsidyRates.map(rate => (
            <div class="feature-card" style="text-align: center; background: var(--canvas);">
              <div style="font-family: var(--font-mono); font-size: 24px; font-weight: 500; color: #e57c00; margin-bottom: 8px;">{rate.subsidy}</div>
              <div style="font-size: 13px; color: var(--muted);">{rate.capacity}</div>
            </div>
          ))}
        </div>

        <!-- Two Column: Eligibility + Documents -->
        <div class="grid md:grid-cols-2 gap-8">
          <div class="feature-card" style="background: var(--canvas);">
            <h3 class="type-title-md" style="margin-bottom: 20px; display: flex; align-items: center; gap: 8px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Eligibility Criteria
            </h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 12px;" role="list">
              {site.subsidyInfo.pmSuryaGhar.eligibility.map(item => (
                <li style="display: flex; align-items: start; gap: 10px; font-size: 14px; color: var(--body-color);">
                  <span style="display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; border-radius: 9999px; background: rgba(229,124,0,0.08); color: #e57c00; font-size: 10px; font-weight: 700; margin-top: 2px;">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="feature-card" style="background: var(--canvas);">
            <h3 class="type-title-md" style="margin-bottom: 20px; display: flex; align-items: center; gap: 8px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e57c00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Documents Required
            </h3>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 12px;" role="list">
              {site.subsidyInfo.pmSuryaGhar.documents.map(doc => (
                <li style="display: flex; align-items: start; gap: 10px; font-size: 14px; color: var(--body-color);">
                  <span style="display: inline-flex; align-items: center; justify-content: center; width: 18px; height: 18px; border-radius: 9999px; background: rgba(229,124,0,0.08); color: #e57c00; font-size: 10px; font-weight: 700; margin-top: 2px;">✓</span>
                  <span>{doc}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Application Process — band-light -->
  <section class="section band-light" aria-labelledby="process-sub-heading">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <div style="text-align: center; margin-bottom: 48px;">
          <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #e57c00; margin-bottom: 16px;">Step by Step</p>
          <h2 id="process-sub-heading" class="type-display-md">
            How we apply for your subsidy.
          </h2>
        </div>
        <div style="display: flex; flex-direction: column; gap: 32px;">
          {[
            { step: 1, title: 'Register on National Portal', desc: 'We register you on pmsuryagarh.gov.in with your Aadhaar-linked mobile number and electricity consumer details.', time: 'Day 1' },
            { step: 2, title: 'Site Inspection & Design', desc: 'Our engineer visits your property, assesses the roof, and designs an approved solar system tailored to your energy needs.', time: 'Day 2–5' },
            { step: 3, title: 'DISCOM Application', desc: 'We submit the system design to your DISCOM for approval and track the progress until clearance is received.', time: 'Week 1–2' },
            { step: 4, title: 'Professional Installation', desc: 'Our certified team installs your solar system using premium components following all safety and quality standards.', time: 'After approval' },
            { step: 5, title: 'Net Meter Application', desc: 'We apply for your net meter. DISCOM installs it within 30 days, allowing you to export surplus electricity to the grid.', time: 'Within 30 days' },
            { step: 6, title: 'Subsidy Disbursement', desc: 'After commissioning, DISCOM generates the certificate and your subsidy amount is directly credited to your Aadhaar-linked bank account.', time: 'Within 30 working days' },
          ].map(item => (
            <div style="display: flex; gap: 24px; align-items: start;">
              <div style="flex-shrink: 0; width: 40px; height: 40px; border-radius: 12px; background: var(--surface-strong); color: var(--ink); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 600;">
                {item.step}
              </div>
              <div style="flex-1; padding-bottom: 24px; border-bottom: 1px solid var(--hairline);" class="last:border-0">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; margin-bottom: 8px;">
                  <h3 class="type-title-sm">{item.title}</h3>
                  <span class="badge-pill" style="font-size: 11px;">{item.time}</span>
                </div>
                <p style="font-size: 14px; color: var(--body-color); line-height: 1.6;">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PM KUSUM — band-soft -->
  <section class="section band-soft" aria-labelledby="pm-kusum-heading">
    <div class="container">
      <div class="max-w-5xl mx-auto">
        <div style="text-align: center; margin-bottom: 48px;">
          <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #e57c00; margin-bottom: 16px;">For Farmers</p>
          <h2 id="pm-kusum-heading" class="type-display-md" style="margin-bottom: 16px;">
            PM-KUSUM Scheme
          </h2>
          <p style="font-size: 16px; color: var(--body-color); max-width: 520px; margin-inline: auto;">{site.subsidyInfo.pmKusum.description}</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {site.subsidyInfo.pmKusum.subsidyRates.map(rate => (
            <div class="feature-card" style="background: var(--canvas);">
              <h3 class="type-title-sm" style="margin-bottom: 12px;">{rate.component}</h3>
              <p style="font-family: var(--font-mono); font-size: 24px; font-weight: 500; color: #e57c00;">{rate.subsidy}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Commercial Incentives — band-light -->
  <section class="section band-light" aria-labelledby="commercial-incentives-heading">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <div style="text-align: center; margin-bottom: 48px;">
          <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #e57c00; margin-bottom: 16px;">For Businesses</p>
          <h2 id="commercial-incentives-heading" class="type-display-md">Commercial Solar Incentives</h2>
        </div>
        <div style="display: flex; flex-direction: column; gap: 12px;">
          {site.subsidyInfo.commercialIncentives.map(incentive => (
            <div class="feature-card" style="display: flex; align-items: center; gap: 12px; padding: 20px; background: var(--canvas);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#e57c00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0;"><path d="M20 6 9 17l-5-5"/></svg>
              <span style="font-size: 14px; font-weight: 500; color: var(--ink);">{incentive}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <div class="container" style="padding-bottom: 48px;">
    <div class="max-w-5xl mx-auto" style="padding: 20px; border-radius: 12px; border: 1px solid var(--hairline); background: var(--surface-soft);">
      <p style="font-size: 12px; line-height: 1.6; color: var(--muted);">
        <strong>Disclaimer:</strong> Subsidy amounts and scheme details are based on information available as of 2025. Government schemes are subject to change. Please verify current rates at pmsuryagarh.gov.in. Solarelites is an MNRE-empanelled vendor and provides guidance based on current policy. We are not affiliated with the Government of India.
      </p>
    </div>
  </div>

  <!-- CTA — band-dark -->
  <section class="section band-soft" style="text-align: center;">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: clamp(32px, 4.5vw, 52px); font-weight: 400; line-height: 1.0; letter-spacing: -1.3px; color: var(--ink); margin-bottom: 20px; max-width: 560px; margin-inline: auto;">Let Us Handle Your Entire Subsidy</h2>
      <p style="font-size: 16px; color: var(--body-color); margin-bottom: 40px; max-width: 480px; margin-inline: auto; line-height: 1.6;">We've secured ₹48 Cr+ in subsidies for our clients. Let our experts manage your application end-to-end.</p>
      <a href="/contact" class="btn-primary-lg">
        Get Subsidy Assistance
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</Layout>
