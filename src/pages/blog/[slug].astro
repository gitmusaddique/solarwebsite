---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = (await getCollection('blog')).filter(p => !p.data.draft && p.id !== post.id);
const related = allPosts.filter(p => p.data.category === post.data.category).slice(0, 3);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  author: { '@type': 'Person', name: post.data.author },
  datePublished: post.data.date,
  image: post.data.coverImage,
};
---

<Layout title={post.data.title} description={post.data.description} ogImage={post.data.coverImage} schema={articleSchema}>
  <!-- Breadcrumb -->
  <nav class="pt-40 pb-4 container" aria-label="Breadcrumb">
    <ol style="list-style: none; display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--muted); padding: 0;">
      <li><a href="/" style="color: var(--muted); text-decoration: none;" class="hover:underline">Home</a></li>
      <li aria-hidden="true">·</li>
      <li><a href="/blog" style="color: var(--muted); text-decoration: none;" class="hover:underline">Blog</a></li>
      <li aria-hidden="true">·</li>
      <li style="color: var(--ink); text-overflow: ellipsis; white-space: nowrap; overflow: hidden; max-width: 200px;" aria-current="page">{post.data.title}</li>
    </ol>
  </nav>

  <!-- Header -->
  <header class="pb-10 pt-4 container">
    <div class="max-w-3xl">
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
        <span class="badge-pill" style="font-weight: 600;">{post.data.category}</span>
        <span style="font-size: 12px; color: var(--muted);">{post.data.readingTime}</span>
      </div>
      <h1 class="type-display-md" style="margin-bottom: 24px; line-height: 1.25;">{post.data.title}</h1>
      <p style="font-size: 18px; line-height: 1.6; color: var(--body-color); margin-bottom: 32px;">{post.data.description}</p>
      <div style="display: flex; align-items: center; gap: 12px;">
        <div style="width: 40px; height: 40px; border-radius: 9999px; background: var(--surface-strong); color: #0052ff; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 600;">
          {post.data.author.split(' ').map((n: string) => n[0]).join('').slice(0,2)}
        </div>
        <div>
          <div style="font-size: 14px; font-weight: 600; color: var(--ink);">{post.data.author}</div>
          <time style="font-size: 12px; color: var(--muted);" datetime={post.data.date}>
            {new Date(post.data.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>
        </div>
      </div>
    </div>
  </header>

  <!-- Cover Image -->
  <div class="container pb-12">
    <div style="border-radius: var(--radius-xl); overflow: hidden; border: 1px solid var(--hairline); background: var(--surface-soft);" class="max-w-4xl aspect-[16/7]">
      <img src={post.data.coverImage} alt={post.data.title} class="w-full h-full object-cover" width="800" height="350" />
    </div>
  </div>

  <!-- Content -->
  <div class="container pb-20">
    <div class="grid lg:grid-cols-[1fr_280px] gap-12 max-w-5xl">
      <article class="prose max-w-none">
        <Content />
      </article>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <!-- Tags -->
          {post.data.tags.length > 0 && (
            <div class="feature-card" style="background: var(--canvas); padding: 20px;">
              <h3 class="type-title-sm" style="margin-bottom: 12px;">Tags</h3>
              <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                {post.data.tags.map(tag => (
                  <span class="badge-pill" style="font-size: 11px; padding: 4px 10px; background: var(--surface-soft); color: var(--body-color);">{tag}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Share -->
          <div class="feature-card" style="background: var(--canvas); padding: 20px;">
            <h3 class="type-title-sm" style="margin-bottom: 12px;">Share</h3>
            <div style="display: flex; gap: 8px;">
              <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent('https://www.solarelites.in/blog/' + post.id)}`} target="_blank" rel="noopener noreferrer" class="btn-secondary" style="flex: 1; justify-content: center; font-size: 12px; height: 36px; padding: 0 12px;" aria-label="Share on Twitter">Twitter</a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent('https://www.solarelites.in/blog/' + post.id)}`} target="_blank" rel="noopener noreferrer" class="btn-secondary" style="flex: 1; justify-content: center; font-size: 12px; height: 36px; padding: 0 12px;" aria-label="Share on LinkedIn">LinkedIn</a>
            </div>
          </div>

          <!-- CTA -->
          <div class="feature-card" style="background: var(--canvas); border-color: #0052ff; padding: 20px; box-shadow: 0 4px 20px rgba(0,82,255,0.05);">
            <h3 class="type-title-sm" style="margin-bottom: 8px; color: #0052ff;">Ready to Go Solar?</h3>
            <p style="font-size: 12px; line-height: 1.5; color: var(--body-color); margin-bottom: 16px;">Get a free consultation and site assessment from our experts.</p>
            <a href="/contact" class="btn-primary" style="display: flex; justify-content: center; width: 100%; font-size: 13px; height: 36px; padding: 0 12px;">Get Free Quote</a>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <!-- Related Posts — band-soft -->
  {related.length > 0 && (
    <section class="section band-soft" style="border-top: 1px solid var(--hairline);" aria-labelledby="related-heading">
      <div class="container">
        <h2 id="related-heading" class="type-display-sm" style="margin-bottom: 40px;">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {related.map(relPost => (
            <article class="feature-card flex flex-col group" style="background: var(--canvas); padding: 16px;">
              <a href={`/blog/${relPost.id}`} class="group block" style="text-decoration: none;">
                <div class="aspect-[16/9] rounded-xl mb-4 overflow-hidden" style="background: var(--surface-soft); border: 1px solid var(--hairline-soft);">
                  <img src={relPost.data.coverImage} alt={relPost.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" width="300" height="170" />
                </div>
              </a>
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                <span class="badge-pill" style="font-size: 10px; padding: 2px 8px;">{relPost.data.category}</span>
              </div>
              <h3 class="type-title-sm" style="margin-bottom: 0;">
                <a href={`/blog/${relPost.id}`} style="color: var(--ink); text-decoration: none;" class="hover:opacity-80 transition-opacity">{relPost.data.title}</a>
              </h3>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
