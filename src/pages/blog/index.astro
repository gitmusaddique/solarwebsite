---
import Layout from '../../layouts/Layout.astro';
import site from '../../config/site.json';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).filter(p => !p.data.draft).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categories = ['All', ...new Set(posts.map(p => p.data.category))];
---

<Layout
  title="Blog – Solar Energy Insights, Guides & News"
  description="Expert insights on solar installation, government subsidies, ROI analysis, and the latest in Maharashtra's solar energy sector."
>
  <!-- Hero — band-light, display-xl weight 400 -->
  <section class="relative subpage-hero band-light">
    <div class="container text-center">
      <h1 class="aurora-title" style="font-size: clamp(36px, 7vw, 72px); margin-bottom: 24px;">
        From Our Blog
        <span class="aurora-overlay" aria-hidden="true">
          <span class="aurora-overlay__item"></span>
          <span class="aurora-overlay__item"></span>
          <span class="aurora-overlay__item"></span>
          <span class="aurora-overlay__item"></span>
        </span>
      </h1>
      <p style="font-size: 18px; color: var(--body-color); max-width: 600px; margin-inline: auto; line-height: 1.6;">
        Expert guides, case studies, and policy updates to help you make the most of solar energy in Maharashtra.
      </p>
    </div>
  </section>

  <!-- Blog Grid — band-soft -->
  <section class="section band-soft pb-28" aria-label="Blog posts">
    <div class="container">
      <!-- Category Filter — Coinbase pill buttons -->
      <div class="flex flex-wrap gap-x-3 gap-y-4" style="margin-top: 32px; margin-bottom: 48px;" role="tablist" aria-label="Filter blog posts by category">
        {categories.map(cat => (
          <button
            type="button"
            class="category-btn"
            style="display: inline-flex; align-items: center; justify-content: center; padding: 8px 18px; height: 38px; font-size: 13px; font-weight: 600; border-radius: var(--radius-pill); border: 2px solid var(--primary); background: var(--canvas); color: var(--body-color); cursor: pointer; transition: all 0.15s ease;"
            data-category={cat}
            role="tab"
            aria-selected={cat === 'All' ? 'true' : 'false'}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Posts Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="posts-grid">
        {posts.map((post, idx) => {
          return (
            <article
              class="feature-card feature-card-cream flex flex-col group"
              style="padding: 32px; transition: transform 0.2s ease, border-color 0.2s ease; display: flex; border: 2px solid var(--primary) !important;"
              data-category={post.data.category}
            >
              <a href={`/blog/${post.id}`} class="group block" style="text-decoration: none; margin-bottom: 24px;" aria-label={`Read: ${post.data.title}`}>
                <div class="aspect-[16/9] rounded-xl overflow-hidden" style="background: var(--surface-soft); border: 2px solid var(--primary);">
                  <img
                    src={post.data.coverImage}
                    alt={post.data.title}
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    width="400"
                    height="225"
                  />
                </div>
              </a>
              <div class="flex flex-col flex-1">
                <div>
                  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 16px;">
                    <span class="badge-pill" style="font-size: 11px; padding: 4px 10px; font-weight: 600;">{post.data.category}</span>
                    <span style="font-size: 12px; color: var(--ink); opacity: 0.8; font-weight: 500;">{post.data.readingTime}</span>
                  </div>
                  <h2 class="type-title-md" style="margin-bottom: 16px; font-weight: 600; line-height: 1.4;">
                    <a href={`/blog/${post.id}`} style="color: var(--ink); text-decoration: none;" class="hover:opacity-80 transition-opacity">{post.data.title}</a>
                  </h2>
                  <p style="font-size: 14px; line-height: 1.6; color: var(--ink); margin-bottom: 24px; flex: 1; opacity: 0.9;">{post.data.description}</p>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: var(--ink); border-top: 2px solid var(--primary); padding-top: 16px; margin-top: auto; opacity: 0.9;">
                  <span style="font-weight: 600; color: var(--ink);">{post.data.author}</span>
                  <time datetime={post.data.date} style="font-weight: 500;">{new Date(post.data.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-20" style="color: var(--muted);">
          <p>No blog posts found.</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const articles = document.querySelectorAll<HTMLElement>('#posts-grid article');

  function updateActiveButton(activeBtn: HTMLButtonElement) {
    btns.forEach(b => {
      b.setAttribute('aria-selected', 'false');
      b.style.background = 'var(--canvas)';
      b.style.color = 'var(--body-color)';
      b.style.borderColor = 'var(--primary)';
    });
    activeBtn.setAttribute('aria-selected', 'true');
    activeBtn.style.background = 'var(--primary)';
    activeBtn.style.color = 'var(--on-primary)';
    activeBtn.style.borderColor = 'var(--primary)';
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category!;
      updateActiveButton(btn);

      articles.forEach(article => {
        const show = cat === 'All' || article.dataset.category === cat;
        article.style.display = show ? '' : 'none';
      });
    });
  });

  // Set initial active state
  const firstBtn = document.querySelector<HTMLButtonElement>('.category-btn[data-category="All"]');
  if (firstBtn) {
    updateActiveButton(firstBtn);
  }
</script>
