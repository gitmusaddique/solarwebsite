---
import Layout from '../layouts/Layout.astro';
import site from '../../config/site.json';
---

<Layout
  title="Solar Installation Services – Residential, Commercial, Industrial & Agricultural"
  description="Complete solar installation services across India. Residential, commercial, industrial, and agricultural solar with government subsidy assistance."
>
  <!-- Hero — hero-band-light: canvas bg, display-xl weight 400 headline -->
  <section class="relative pt-48 pb-20 band-light" aria-labelledby="services-hero-heading">
    <div class="container text-center">
      <h1 id="services-hero-heading" class="type-display-xl" style="margin-bottom: 24px;">
        End-to-End Solar Solutions
      </h1>
      <p style="font-size: 18px; color: var(--body-color); max-width: 600px; margin-inline: auto; line-height: 1.6;">
        From a single rooftop to a multi-megawatt industrial park — we deliver precision-engineered solar systems that maximise your returns.
      </p>
    </div>
  </section>

  <!-- Services Detail — rotating bands -->
  {site.services.map((service, i) => (
    <section
      id={service.id}
      class={`section ${i % 2 !== 0 ? 'band-soft' : 'band-light'}`}
      aria-labelledby={`service-${service.id}-heading`}
      style={i > 0 ? "border-top: 1px solid var(--hairline);" : ""}
    >
      <div class="container">
        <div class={`grid md:grid-cols-2 gap-16 items-center max-w-5xl mx-auto ${i % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
          <div class={i % 2 !== 0 ? 'md:order-2' : ''}>
            <div class="badge-pill" style="margin-bottom: 24px;">
              Starting from {service.startingPrice}
            </div>
            <h2 id={`service-${service.id}-heading`} class="type-display-lg" style="margin-bottom: 24px;">
              {service.title}
            </h2>
            <p style="font-size: 16px; line-height: 1.6; color: var(--body-color); margin-bottom: 32px;">
              {service.description}
            </p>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 12px; margin-bottom: 32px;" role="list">
              {service.features.map(feature => (
                <li style="display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--body-color);">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0052ff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink: 0;"><path d="M20 6 9 17l-5-5"/></svg>
                  {feature}
                </li>
              ))}
            </ul>
            <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
              <a href="/contact" class="btn-primary">
                Get {service.title} Quote
              </a>
              <span style="font-size: 14px; color: var(--muted);">{service.timeline}</span>
            </div>
          </div>

          <!-- Why choose card: product-ui-card or feature-card -->
          <div class={`${i % 2 !== 0 ? 'md:order-1' : ''} feature-card`} style="background: var(--canvas);">
            <div style="width: 44px; height: 44px; border-radius: 9999px; background: var(--surface-strong); display: flex; align-items: center; justify-content: center; margin-bottom: 24px;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0052ff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                {service.id === 'residential' && <><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></>}
                {service.id === 'commercial' && <><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/></>}
                {service.id === 'industrial' && <path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/>}
                {service.id === 'agriculture' && <><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></>}
              </svg>
            </div>
            <h3 class="type-title-md" style="margin-bottom: 16px;">Why choose {service.title}?</h3>
            <div style="display: flex; flex-direction: column; gap: 2px;">
              {[
                { label: 'Installation Time', value: service.timeline },
                { label: 'Starting Price', value: service.startingPrice },
                { label: 'Warranty', value: '25-year panel performance' },
                { label: 'Subsidy', value: service.id === 'residential' ? 'Up to ₹78,000' : service.id === 'agriculture' ? 'PM-KUSUM – 60% subsidy' : 'Accelerated depreciation 40%' },
              ].map(item => (
                <div style="display: flex; justify-content: space-between; align-items: center; padding-block: 12px; border-bottom: 1px solid var(--hairline-soft);" class="last:border-0">
                  <span style="font-size: 14px; color: var(--muted);">{item.label}</span>
                  <span style="font-size: 14px; font-weight: 600; color: var(--ink);">{item.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Process — band-soft -->
  <section class="section band-soft" style="border-top: 1px solid var(--hairline);" aria-labelledby="services-process-heading">
    <div class="container">
      <div style="max-width: 480px; margin-bottom: 64px;">
        <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #0052ff; margin-bottom: 16px;">Our Process</p>
        <h2 id="services-process-heading" class="type-display-md">
          How we deliver every project.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {site.process.map(step => (
          <div class="feature-card">
            <div style="font-family: var(--font-mono); font-size: 12px; font-weight: 500; color: var(--muted); text-transform: uppercase; margin-bottom: 16px;">Step {String(step.step).padStart(2,'0')}</div>
            <h3 class="type-title-md" style="margin-bottom: 8px;">{step.title}</h3>
            <p style="font-size: 14px; color: var(--body-color); line-height: 1.6;">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Maintenance section — band-light -->
  <section class="section band-light" style="border-top: 1px solid var(--hairline);" id="maintenance" aria-labelledby="maintenance-heading">
    <div class="container max-w-4xl mx-auto">
      <div style="text-align: center; margin-bottom: 48px;">
        <p style="font-size: 12px; font-weight: 600; text-transform: uppercase; color: #0052ff; margin-bottom: 16px;">After-Sales</p>
        <h2 id="maintenance-heading" class="type-display-md" style="margin-bottom: 16px;">
          Lifetime maintenance & support.
        </h2>
        <p style="font-size: 16px; color: var(--body-color); max-width: 520px; margin-inline: auto;">Your solar investment is protected with comprehensive post-installation support.</p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {[
          { title: 'Free First Year', desc: 'Complete Annual Maintenance Contract included in every installation at no extra cost.', icon: 'gift' },
          { title: 'Real-Time Monitoring', desc: 'Monitor your system performance 24/7 via our mobile app with instant alerts.', icon: 'activity' },
          { title: '24/7 Emergency Support', desc: 'Dedicated emergency helpline ensures any critical issue is resolved within 24 hours.', icon: 'headphones' },
        ].map(card => (
          <div class="feature-card" style="text-align: center;">
            <div style="width: 40px; height: 40px; border-radius: 9999px; background: var(--surface-strong); display: flex; align-items: center; justify-content: center; margin-inline: auto; margin-bottom: 20px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0052ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                {card.icon === 'gift' && <><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></>}
                {card.icon === 'activity' && <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>}
                {card.icon === 'headphones' && <><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></>}
              </svg>
            </div>
            <h3 class="type-title-md" style="margin-bottom: 8px;">{card.title}</h3>
            <p style="font-size: 14px; color: var(--body-color); line-height: 1.6;">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — band-dark -->
  <section class="section band-soft" style="text-align: center; border-top: 1px solid var(--hairline);">
    <div class="container">
      <h2 style="font-family: var(--font-display); font-size: clamp(32px, 4.5vw, 52px); font-weight: 400; line-height: 1.0; letter-spacing: -1.3px; color: var(--ink); margin-bottom: 20px; max-width: 560px; margin-inline: auto;">Get a Free Site Assessment</h2>
      <p style="font-size: 16px; color: var(--body-color); margin-bottom: 40px; max-width: 480px; margin-inline: auto; line-height: 1.6;">Our engineers will visit your property, assess your energy needs, and provide a detailed proposal — completely free of charge.</p>
      <a href="/contact" class="btn-primary-lg">
        Book Free Assessment
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</Layout>
