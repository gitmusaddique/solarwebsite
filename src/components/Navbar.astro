---
import site from '../../config/site.json';

const navLinks = [
  { href: '/', label: 'Home', i18nKey: 'nav.home', icon: 'home' },
  { href: '/services', label: 'Services', i18nKey: 'nav.services', icon: 'services' },
  { href: '/subsidy', label: 'Subsidy', i18nKey: 'nav.subsidy', icon: 'subsidy' },
  { href: '/projects', label: 'Projects', i18nKey: 'nav.projects', icon: 'projects' },
  { href: '/gallery', label: 'Gallery', i18nKey: 'nav.gallery', icon: 'gallery' },
  { href: '/blog', label: 'Blog', i18nKey: 'nav.blog', icon: 'blog' },
  { href: '/calculator', label: 'Calculator', i18nKey: 'nav.calculator', icon: 'calculator' },
  { href: '/about', label: 'Company', i18nKey: 'nav.about', icon: 'about' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

function getIconSvg(iconName: string) {
  if (iconName === 'home') {
    return `<svg class="nav-menu-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`;
  }
  if (iconName === 'services') {
    return `<svg class="nav-menu-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`;
  }
  if (iconName === 'subsidy') {
    return `<svg class="nav-menu-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`;
  }
  if (iconName === 'projects') {
    return `<svg class="nav-menu-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>`;
  }
  if (iconName === 'gallery') {
    return `<svg class="nav-menu-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`;
  }
  if (iconName === 'blog') {
    return `<svg class="nav-menu-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`;
  }
  if (iconName === 'calculator') {
    return `<svg class="nav-menu-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12" y2="18"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="8" y2="10"/><line x1="12" y1="10" x2="12" y2="10"/><line x1="16" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="8" y2="14"/><line x1="16" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="8" y2="18"/><line x1="16" y1="18" x2="16" y2="18"/></svg>`;
  }
  if (iconName === 'about') {
    return `<svg class="nav-menu-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;
  }
  return '';
}
---

<!-- top-nav-light: height 80px, canvas bg, ink text, nav-link type -->
<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 ease-out"
  style="height: 80px; background: var(--canvas); border-bottom: 1px solid var(--canvas);"
  role="banner"
>
  <nav class="container h-full flex items-center justify-between gap-4" aria-label="Main navigation">

    <!-- Logo Image -->
    <a href="/" class="flex items-center shrink-0" aria-label="Solarelites — home">
      <img src="/images/logo.png" alt="Solarelites Logo" class="h-10 sm:h-12 md:h-14 w-auto" style="display: block;" />
    </a>

    <!-- Desktop nav links — nav-link: 14px / 600 -->
    <ul class="hidden lg:flex items-center gap-2 shrink-0" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            <span data-i18n={link.i18nKey}>{link.label}</span>
          </a>
        </li>
      ))}
    </ul>

<style>
  .nav-link {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    text-decoration: none;
    position: relative;
    padding: 8px 0;
    margin-inline: 8px;
    color: var(--muted);
    transition: color 0.2s ease;
    display: inline-block;
  }

  .nav-link:hover {
    color: var(--ink);
  }

  .nav-link.active {
    color: var(--saffron);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 100%;
    transform: scaleX(0);
    height: 2px;
    bottom: 2px;
    left: 0;
    background-color: var(--saffron);
    transform-origin: bottom right;
    transition: transform 0.25s ease-out;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  .nav-link.active::after {
    transform: scaleX(1);
  }

  .nav-menu-icon {
    width: 18px;
    height: 18px;
    stroke-width: 2.2px;
    color: currentColor;
    display: block;
  }

  .lang-select-dropdown {
    appearance: none;
    -webkit-appearance: none;
    background-color: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-pill);
    padding: 6px 28px 6px 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%23000000' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='m6 9 6 6 6-6'/></svg>");
    background-repeat: no-repeat;
    background-position: right 8px center;
    background-size: 12px;
    transition: all 0.15s ease;
    height: 38px;
  }

  .lang-select-dropdown:hover {
    border-color: var(--primary);
  }

  .lang-select-dropdown:focus {
    outline: 2px solid var(--primary);
    border-color: var(--primary);
  }

  .phone-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    border: 1px solid var(--hairline);
    background: color-mix(in srgb, var(--primary) 8%, var(--canvas));
    color: var(--muted-teal);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .phone-icon-btn:hover {
    background: var(--primary);
    color: var(--on-primary);
    border-color: var(--primary);
    transform: translateY(-1px);
  }

  .phone-icon-btn:active {
    transform: translateY(0);
  }
</style>

    <!-- Right: Language switcher + phone + CTA -->
    <div class="flex items-center gap-3 shrink-0 flex-nowrap">

      <!-- Language Switcher Dropdown (Desktop only) -->
      <div class="hidden sm:block">
        <select class="lang-select-dropdown" aria-label="Change Language">
          <option value="en">English</option>
          <option value="hi">हिंदी</option>
          <option value="mr">मराठी</option>
        </select>
      </div>

      <!-- Language Switcher Dropdown (Mobile only) -->
      <div class="block sm:hidden">
        <select class="lang-select-dropdown" style="padding: 4px 22px 4px 8px; font-size: 12px; height: 34px; background-position: right 6px center;" aria-label="Change Language">
          <option value="en">EN</option>
          <option value="hi">HI</option>
          <option value="mr">MR</option>
        </select>
      </div>

      <!-- Phone Icon Button -->
      <a
        href={`tel:${site.contact.phoneRaw}`}
        class="phone-icon-btn"
        aria-label={`Call us at ${site.contact.phone}`}
        title={`Call us at ${site.contact.phone}`}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.63 4.35 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>

      <button
        id="mobile-toggle"
        type="button"
        class="lg:hidden p-2 rounded-lg"
        style="color: var(--ink);"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle menu"
      >
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="fixed top-[80px] left-0 right-0 bottom-0 z-40 overflow-y-auto lg:hidden opacity-0 pointer-events-none -translate-y-4 transition-all duration-300 ease-out hidden"
    style="height: calc(100dvh - 80px); border-top: 1px solid var(--hairline-soft); background: var(--canvas);"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <div class="container py-6 flex flex-col justify-between" style="min-height: 100%;">
      <div class="flex flex-col gap-6">
        <!-- Navigation Links (Styled like the premium card in the image) -->
        <div class="overflow-hidden border border-[var(--hairline)] rounded-2xl" style="background: var(--canvas);">
          <ul class="flex flex-col" role="list">
            {navLinks.map((link, idx) => (
              <li class={idx < navLinks.length - 1 ? 'border-b border-[var(--hairline-soft)]' : ''}>
                <a
                  href={link.href}
                  class="flex items-center justify-center gap-3 px-6 py-5.5 transition-all"
                  style={`font-size: 16.5px; font-weight: 600; text-decoration: none; color: ${isActive(link.href) ? 'var(--on-primary)' : 'var(--ink)'}; background: ${isActive(link.href) ? 'var(--primary)' : 'var(--canvas)'}; min-height: 56px;`}
                  aria-current={isActive(link.href) ? 'page' : undefined}
                  onmouseover={!isActive(link.href) ? "this.style.background='var(--surface-soft)'" : ""}
                  onmouseout={!isActive(link.href) ? "this.style.background='var(--canvas)'" : ""}
                >
                  <span class="flex-shrink-0 flex items-center justify-center" style={`width: 20px; height: 20px; color: ${isActive(link.href) ? 'var(--on-primary)' : 'var(--muted)'};`}>
                    <Fragment set:html={getIconSvg(link.icon)} />
                  </span>
                  <span data-i18n={link.i18nKey}>{link.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Call & Quote Actions -->
      <div class="pt-6 flex flex-col gap-3" style="border-top: 1px solid var(--hairline-soft); margin-top: 24px;">
        <!-- Language Switcher (Mobile Drawer) -->
        <div class="flex items-center justify-between p-3 border border-[var(--hairline-soft)] rounded-xl mb-1" style="background: var(--surface-soft);">
          <span class="text-sm font-semibold flex items-center gap-2" style="color: var(--ink);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span>Language / भाषा</span>
          </span>
          <select class="lang-select-dropdown" style="height: 36px; padding: 4px 28px 4px 12px; width: auto;" aria-label="Change Language">
            <option value="en">English</option>
            <option value="hi">हिंदी</option>
            <option value="mr">मराठी</option>
          </select>
        </div>

        <a href={`tel:${site.contact.phoneRaw}`} class="btn-outline-dark justify-center gap-2" style="height: 48px; font-size: 15px; width: 100%;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.63 4.35 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>{site.contact.phone}</span>
        </a>
        <a href="/contact" class="btn-primary justify-center" style="height: 48px; font-size: 15px; width: 100%;" data-i18n="nav.quote">Get Free Quote</a>
      </div>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const toggle = document.getElementById('mobile-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;
  const iconMenu  = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll: add hairline border when scrolled
  function onScroll() {
    const scrolled = window.scrollY > 4;
    navbar.style.borderBottomColor = scrolled ? 'var(--hairline-soft)' : 'var(--canvas)';
    navbar.style.backgroundColor   = 'var(--canvas)';
    navbar.style.backdropFilter = '';
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile toggle
  let open = false;

  function setMenuOpen(shouldOpen: boolean) {
    open = shouldOpen;
    toggle.setAttribute('aria-expanded', String(open));
    iconMenu.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
    
    if (open) {
      menu.classList.remove('hidden');
      // Force browser reflow to enable transition
      menu.offsetHeight;
      menu.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
      menu.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
      document.body.style.overflow = 'hidden';
    } else {
      menu.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
      menu.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      document.body.style.overflow = '';
      // Wait for transition to complete before setting display hidden
      setTimeout(() => {
        if (!open) {
          menu.classList.add('hidden');
        }
      }, 300);
    }
  }

  toggle.addEventListener('click', () => {
    setMenuOpen(!open);
  });

  // Close menu when links are clicked
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      setMenuOpen(false);
    });
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && open) {
      setMenuOpen(false);
      toggle.focus();
    }
  });
</script>
