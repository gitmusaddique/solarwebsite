---
import site from '../../config/site.json';

const navLinks = [
  { href: '/', label: 'Home', i18nKey: 'nav.home' },
  { href: '/services', label: 'Services', i18nKey: 'nav.services' },
  { href: '/subsidy', label: 'Subsidy', i18nKey: 'nav.subsidy' },
  { href: '/projects', label: 'Projects', i18nKey: 'nav.projects' },
  { href: '/gallery', label: 'Gallery', i18nKey: 'nav.gallery' },
  { href: '/blog', label: 'Blog', i18nKey: 'nav.blog' },
  { href: '/calculator', label: 'Calculator', i18nKey: 'nav.calculator' },
  { href: '/about', label: 'Company', i18nKey: 'nav.about' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!-- top-nav-light: height 64px, canvas bg, ink text, nav-link type -->
<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-200"
  style="height: 64px; background: #ffffff; border-bottom: 1px solid transparent;"
  role="banner"
>
  <nav class="container h-full flex items-center justify-between gap-4" aria-label="Main navigation">

    <!-- Logo Image -->
    <a href="/" class="flex items-center shrink-0" aria-label="Solarelites — home">
      <img src="/images/logo.png" alt="Solarelites Logo" class="h-9 w-auto" style="display: block;" />
    </a>

    <!-- Desktop nav links — nav-link: 14px / 500 -->
    <ul class="hidden lg:flex items-center gap-2 shrink-0" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
            aria-current={isActive(link.href) ? 'page' : undefined}
            data-i18n={link.i18nKey}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

<style>
  .nav-link {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    text-decoration: none;
    position: relative;
    padding: 8px 0;
    margin-inline: 8px;
    color: rgba(10, 11, 13, 0.6);
    transition: color 0.2s ease;
    display: inline-block;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #0a0b0d;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 100%;
    transform: scaleX(0);
    height: 2px;
    bottom: 2px;
    left: 0;
    background-color: #e57c00;
    transform-origin: bottom right;
    transition: transform 0.25s ease-out;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  .nav-link.active::after {
    transform: scaleX(1);
  }

  .lang-select-dropdown {
    appearance: none;
    -webkit-appearance: none;
    background-color: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-pill);
    padding: 6px 28px 6px 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%230a0b0d' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='m6 9 6 6 6-6'/></svg>");
    background-repeat: no-repeat;
    background-position: right 8px center;
    background-size: 12px;
    transition: all 0.15s ease;
    height: 38px;
  }

  .lang-select-dropdown:hover {
    border-color: #e57c00;
  }

  .lang-select-dropdown:focus {
    outline: none;
    border-color: #e57c00;
    box-shadow: 0 0 0 2px rgba(229, 124, 0, 0.15);
  }

  .phone-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(229, 124, 0, 0.25);
    background: rgba(229, 124, 0, 0.05);
    color: #e57c00;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .phone-icon-btn:hover {
    background: #e57c00;
    color: #ffffff;
    border-color: #e57c00;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(229, 124, 0, 0.2);
  }

  .phone-icon-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 6px rgba(229, 124, 0, 0.1);
  }
</style>

    <!-- Right: Language switcher + phone + CTA -->
    <div class="flex items-center gap-3 shrink-0 flex-nowrap">
      
      <!-- Language Switcher Dropdown (Desktop) -->
      <div class="hidden md:block">
        <select class="lang-select-dropdown" aria-label="Change Language">
          <option value="en">English</option>
          <option value="hi">हिंदी</option>
          <option value="mr">मराठी</option>
        </select>
      </div>

      <!-- Phone Icon Button -->
      <a
        href={`tel:${site.contact.phoneRaw}`}
        class="phone-icon-btn"
        aria-label={`Call us at ${site.contact.phone}`}
        title={`Call us at ${site.contact.phone}`}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.63 4.35 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>

      <!-- button-primary pill -->
      <a href="/contact" class="btn-primary hidden sm:inline-flex" style="height: 40px; padding: 0 16px; font-size: 13px;" data-i18n="nav.quote">
        Get Free Quote
      </a>

      <!-- Mobile toggle -->
      <button
        id="mobile-toggle"
        type="button"
        class="lg:hidden p-2 rounded-lg"
        style="color: #0a0b0d;"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle menu"
      >
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="fixed top-[64px] left-0 right-0 bottom-0 bg-white/98 backdrop-blur-md z-40 overflow-y-auto lg:hidden opacity-0 pointer-events-none -translate-y-4 transition-all duration-300 ease-out hidden"
    style="height: calc(100dvh - 64px); border-top: 1px solid rgba(10, 11, 13, 0.08);"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <div class="container py-6 flex flex-col justify-between min-h-full">
      <div>
        <!-- Language Switcher (Mobile) -->
        <div class="mb-6 px-4 py-4 rounded-2xl" style="background: var(--surface-soft); border: 1px solid var(--hairline-soft);">
          <div class="flex justify-between items-center mb-3">
            <span style="font-size: 13px; font-weight: 700; color: var(--ink); text-transform: uppercase; letter-spacing: 0.5px;">Language / भाषा</span>
          </div>
          <div class="flex gap-2">
            <button type="button" class="mobile-lang-btn flex-1 py-2 rounded-full text-xs font-semibold border text-center transition-all cursor-pointer" data-lang="en" style="height: 36px;">
              English
            </button>
            <button type="button" class="mobile-lang-btn flex-1 py-2 rounded-full text-xs font-semibold border text-center transition-all cursor-pointer" data-lang="hi" style="height: 36px;">
              हिंदी
            </button>
            <button type="button" class="mobile-lang-btn flex-1 py-2 rounded-full text-xs font-semibold border text-center transition-all cursor-pointer" data-lang="mr" style="height: 36px;">
              मराठी
            </button>
          </div>
        </div>
        
        <ul class="flex flex-col gap-2.5" role="list">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="flex items-center justify-between px-4 py-3.5 rounded-xl transition-all"
                style={`font-size: 15px; font-weight: 600; color: ${isActive(link.href) ? '#e57c00' : 'var(--ink)'}; text-decoration: none; background: ${isActive(link.href) ? 'rgba(229, 124, 0, 0.05)' : 'var(--surface-soft)'}; border: 1px solid ${isActive(link.href) ? 'rgba(229,124,0,0.15)' : 'var(--hairline-soft)'};`}
                aria-current={isActive(link.href) ? 'page' : undefined}
                data-i18n={link.i18nKey}
              >
                <span>{link.label}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style={`color: ${isActive(link.href) ? '#e57c00' : 'var(--muted)'};`}><path d="m9 18 6-6-6-6"/></svg>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-8 pt-6 flex flex-col gap-3" style="border-top: 1px solid rgba(10, 11, 13, 0.08);">
        <a href={`tel:${site.contact.phoneRaw}`} class="btn-outline-dark justify-center gap-2" style="height: 48px; font-size: 15px; border: 1px solid var(--hairline); width: 100%;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.63 4.35 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>{site.contact.phone}</span>
        </a>
        <a href="/contact" class="btn-primary justify-center" style="height: 48px; font-size: 15px; width: 100%; box-shadow: 0 4px 14px rgba(229,124,0,0.15);" data-i18n="nav.quote">Get Free Quote</a>
      </div>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const toggle = document.getElementById('mobile-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;
  const iconMenu  = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll: add hairline border when scrolled
  function onScroll() {
    const scrolled = window.scrollY > 4;
    navbar.style.borderBottomColor = scrolled ? 'rgba(10, 11, 13, 0.1)' : 'transparent';
    navbar.style.backgroundColor   = scrolled ? 'rgba(255,255,255,0.97)' : '#ffffff';
    if (scrolled) navbar.style.backdropFilter = 'blur(8px)';
    else          navbar.style.backdropFilter = '';
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile toggle
  let open = false;

  function setMenuOpen(shouldOpen: boolean) {
    open = shouldOpen;
    toggle.setAttribute('aria-expanded', String(open));
    iconMenu.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
    
    if (open) {
      menu.classList.remove('hidden');
      // Force browser reflow to enable transition
      menu.offsetHeight;
      menu.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-4');
      menu.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
      document.body.style.overflow = 'hidden';
    } else {
      menu.classList.add('opacity-0', 'pointer-events-none', '-translate-y-4');
      menu.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      document.body.style.overflow = '';
      // Wait for transition to complete before setting display hidden
      setTimeout(() => {
        if (!open) {
          menu.classList.add('hidden');
        }
      }, 300);
    }
  }

  toggle.addEventListener('click', () => {
    setMenuOpen(!open);
  });

  // Close menu when links are clicked
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      setMenuOpen(false);
    });
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && open) {
      setMenuOpen(false);
      toggle.focus();
    }
  });
</script>
