---
import site from '../../config/site.json';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/subsidy', label: 'Subsidy' },
  { href: '/projects', label: 'Projects' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/blog', label: 'Blog' },
  { href: '/calculator', label: 'Calculator' },
  { href: '/about', label: 'Company' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<!-- top-nav-light: height 64px, canvas bg, ink text, nav-link type -->
<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-200"
  style="height: 64px; background: #ffffff; border-bottom: 1px solid transparent;"
  role="banner"
>
  <nav class="container h-full flex items-center justify-between" aria-label="Main navigation">

    <!-- Wordmark -->
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Solarelites — home">
      <div
        class="w-7 h-7 rounded-full flex items-center justify-center shrink-0"
        style="background: #0052ff;"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="12" cy="12" r="4.5" fill="white"/>
          <line x1="12" y1="2" x2="12" y2="5.5" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="12" y1="18.5" x2="12" y2="22" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="2" y1="12" x2="5.5" y2="12" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="18.5" y1="12" x2="22" y2="12" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="4.93" y1="4.93" x2="7.34" y2="7.34" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="16.66" y1="16.66" x2="19.07" y2="19.07" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="19.07" y1="4.93" x2="16.66" y2="7.34" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="7.34" y1="16.66" x2="4.93" y2="19.07" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
      </div>
      <span style="font-family: var(--font-display); font-size: 16px; font-weight: 600; color: #0a0b0d; letter-spacing: -0.3px;">
        Solar<span style="color: #0052ff;">elites</span>
      </span>
    </a>

    <!-- Desktop nav links — nav-link: 14px / 500 -->
    <ul class="hidden lg:flex items-center gap-5" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

<style>
  .nav-link {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    text-decoration: none;
    position: relative;
    padding: 8px 0;
    margin-inline: 12px;
    color: rgba(10, 11, 13, 0.6);
    transition: color 0.2s ease;
    display: inline-block;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #0a0b0d;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    width: 100%;
    transform: scaleX(0);
    height: 2px;
    bottom: 2px;
    left: 0;
    background-color: #0052ff;
    transform-origin: bottom right;
    transition: transform 0.25s ease-out;
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  .nav-link.active::after {
    transform: scaleX(1);
  }
</style>

    <!-- Right: phone + CTA -->
    <div class="flex items-center gap-3">
      <a
        href={`tel:${site.contact.phoneRaw}`}
        class="hidden md:flex items-center gap-1.5 shrink-0 whitespace-nowrap"
        style="font-size: 14px; font-weight: 500; color: rgba(10, 11, 13, 0.6); text-decoration: none; white-space: nowrap;"
        aria-label="Call Solarelites"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.63 4.35 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="hidden xl:inline">{site.contact.phone}</span>
      </a>

      <!-- button-primary pill -->
      <a href="/contact" class="btn-primary hidden sm:inline-flex" style="height: 44px; padding: 0 20px; font-size: 14px;">
        Get Free Quote
      </a>

      <!-- Mobile toggle -->
      <button
        id="mobile-toggle"
        type="button"
        class="lg:hidden p-2 rounded-lg"
        style="color: #0a0b0d;"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle menu"
      >
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden"
    style="background: #ffffff; border-top: 1px solid rgba(10, 11, 13, 0.1);"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <div class="container py-4">
      <ul class="flex flex-col gap-1" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="flex items-center px-3 py-2.5 rounded-lg text-sm font-medium transition-colors"
              style={`font-size: 14px; font-weight: 500; color: ${isActive(link.href) ? '#0052ff' : 'rgba(10, 11, 13, 0.6)'}; text-decoration: none; background: ${isActive(link.href) ? 'rgba(0, 82, 255, 0.05)' : 'transparent'};`}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-4 pt-4 flex flex-col gap-3" style="border-top: 1px solid rgba(10, 11, 13, 0.1);">
        <a href={`tel:${site.contact.phoneRaw}`} class="flex items-center gap-2 px-3 py-2" style="font-size: 14px; color: rgba(10, 11, 13, 0.6); text-decoration: none;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.63 4.35 2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.07 6.07l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {site.contact.phone}
        </a>
        <a href="/contact" class="btn-primary justify-center" style="height: 44px;">Get Free Quote</a>
      </div>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const toggle = document.getElementById('mobile-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;
  const iconMenu  = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll: add hairline border when scrolled
  function onScroll() {
    const scrolled = window.scrollY > 4;
    navbar.style.borderBottomColor = scrolled ? 'rgba(10, 11, 13, 0.1)' : 'transparent';
    navbar.style.backgroundColor   = scrolled ? 'rgba(255,255,255,0.97)' : '#ffffff';
    if (scrolled) navbar.style.backdropFilter = 'blur(8px)';
    else          navbar.style.backdropFilter = '';
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile toggle
  let open = false;
  toggle.addEventListener('click', () => {
    open = !open;
    menu.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    iconMenu.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && open) {
      open = false;
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      iconMenu.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.focus();
    }
  });
</script>
